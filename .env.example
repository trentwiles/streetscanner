# ---------------------------------------------------------------
# mailer.py — SMTP configuration
# ---------------------------------------------------------------

# Hostname of your SMTP server
SMTP_HOST=localhost

# SMTP port — 25 (local relay), 587 (STARTTLS), or 465 (SSL)
SMTP_PORT=25

# Envelope/From address that appears in outgoing emails
SMTP_FROM=streetscanner@localhost

# Leave SMTP_USER and SMTP_PASS blank if your server allows
# unauthenticated relay (e.g. local Postfix / sendmail)
SMTP_USER=
SMTP_PASS=

# ---------------------------------------------------------------
# app.py — GitHub OAuth + session
# ---------------------------------------------------------------

# From GitHub → Settings → Developer settings → OAuth Apps
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Comma-separated GitHub usernames allowed to access /admin
GITHUB_ALLOWED_USERS=trentwiles

# Random string used to sign session cookies — generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=

# Vite dev server origin — leave blank in production (Flask serves the built SPA)
FRONTEND_ORIGIN=http://localhost:5173

# ---------------------------------------------------------------
# app.py — email verification
# ---------------------------------------------------------------

# Public base URL of this server — used to build the confirmation link in verification emails
# In production, set this to your actual domain (e.g. https://streetscanner.example.com)
APP_BASE_URL=http://localhost:5001
