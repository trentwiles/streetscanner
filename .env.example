# Flask secret key — set to a long random string in production
SECRET_KEY=change-me

# Base URL used to build magic-link emails (no trailing slash)
BASE_URL=https://example.com

# SMTP settings for sending magic-link emails
# Leave SMTP_HOST unset to print links to stdout instead of sending email (dev mode)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=you@gmail.com
